---
// src/components/Hero.astro
// ──────────────────────────
// Seção inicial — Google Sans Display, layout Stitch-inspired + AI Chat Widget
import AIChatWidget from './AIChatWidget.astro';
---

<section id="hero" class="hero">
  <div class="container">
    <div class="hero-inner">

      <div class="hero-meta">
        <div class="hero-tag-wrapper">
          <span class="hero-tag-dot"></span>
          <span class="label" data-i18n="hero.tag">Staff AI Engineer &amp; Global NASA Winner</span>
        </div>
        <span class="label">2026</span>
      </div>

      <!-- headline + AI widget (lado a lado) -->
      <div class="hero-center-row">
        <h1 class="hero-headline">
          <span class="headline-line"><span class="code-bracket">&lt;</span>Eduardo</span>
          <span class="headline-line">Ritter<span class="code-bracket">/&gt;</span></span>
        </h1>

        <!-- AI Chat Widget inline -->
        <div class="hero-ai-slot">
          <!-- Label removida conforme pedido pelo usuário -->
          <AIChatWidget />
        </div>
      </div>

      <div class="hero-bottom">
        <div class="hero-content-block">
          <!-- Tagline removida deste local para melhor fluxo visual conforme pedido -->
        </div>

        <div class="scroll-hint">
          <span class="label" data-i18n="hero.scroll">Rolar</span>
          <div class="scroll-line"><div class="scroll-line-inner"></div></div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ─── Center row: headline + AI widget ─── */
  .hero-center-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(32px, 5vw, 64px);
    margin-top: auto;
    margin-bottom: auto;
    flex-wrap: wrap;
  }

  /* Keep the headline always left */
  .hero-center-row .hero-headline {
    margin-top: 0;
    margin-bottom: 0;
    flex-shrink: 0;
  }

  /* AI slot: right side */
  .hero-ai-slot {
    display: flex;
    flex-direction: column;
    gap: 14px;
    flex: 1;
    min-width: 280px;
    max-width: 520px;
  }

  /* Removed .hero-ai-label and labelDotPulse animations */

  /* ─── Responsive: stack on mobile ─── */
  @media (max-width: 900px) {
    .hero-center-row {
      flex-direction: column;
      align-items: flex-start;
    }

    .hero-ai-slot {
      max-width: 100%;
      width: 100%;
    }
  }
</style>
